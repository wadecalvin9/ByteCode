import React, { useEffect, useState, useRef } from 'react';
import { useParams, Link } from 'react-router-dom';
import { 
  Terminal as TerminalIcon, 
  Cpu, 
  Folder, 
  Globe, 
  Activity as ActivityIcon, 
  Shield, 
  ShieldAlert,
  ShieldCheck,
  Wifi, 
  Clock, 
  ChevronRight, 
  ChevronDown,
  ChevronLeft,
  ArrowDown, 
  ArrowUp,
  RefreshCw, 
  Download, 
  Trash2, 
  AlertCircle, 
  CheckCircle2, 
  Monitor, 
  Search,
  Loader2,
  FileText,
  Send,
  Bomb,
  MoreVertical,
  X,
  Maximize2,
  Menu
} from 'lucide-react';
import { agentsApi, tasksApi } from '../utils/api';
import { format } from 'date-fns';

/* ───────────────── Helper Components ───────────────── */

const ProcessTreeNode = ({ node, level, agentPid, highlightedPids }) => {
  const [expanded, setExpanded] = useState(true);
  const isSelf = Number(node.pid) === Number(agentPid);
  const isNew = highlightedPids.has(node.pid);
  
  return (
    <div className="select-none">
      <div 
        className={`flex items-center gap-2 py-1 px-2 rounded-lg transition-colors group ${
          isSelf ? 'bg-primary/10 border border-primary/20' : 
          isNew ? 'bg-emerald-500/10 border border-emerald-500/20' :
          'hover:bg-white/5'
        }`}
        style={{ marginLeft: `${level * 20}px` }}
      >
        <div className="w-4 h-4 flex items-center justify-center">
          {node.children && node.children.length > 0 && (
            <button onClick={() => setExpanded(!expanded)} className="text-slate-600 hover:text-slate-400">
              {expanded ? <ChevronDown className="w-3 h-3" /> : <ChevronRight className="w-3 h-3" />}
            </button>
          )}
        </div>
        <Cpu className={`w-3.5 h-3.5 ${isSelf ? 'text-primary' : 'text-slate-600'}`} />
        <span className="text-[11px] font-mono text-slate-500 w-12">{node.pid}</span>
        <span className={`text-[11px] font-bold ${isSelf ? 'text-white' : 'text-slate-300'}`}>{node.name}</span>
        {isSelf && <span className="text-[8px] font-black uppercase text-primary border border-primary/30 px-1 rounded">SELF</span>}
      </div>
      {expanded && node.children && node.children.map(child => (
        <ProcessTreeNode key={child.pid} node={child} level={level + 1} agentPid={agentPid} highlightedPids={highlightedPids} />
      ))}
    </div>
  );
};

const AgentDetailPage = () => {
  const { id } = useParams();
  const [agent, setAgent] = useState(null);
  const [results, setResults] = useState([]);
  const [pendingTasks, setPendingTasks] = useState([]);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('console');
  const [command, setCommand] = useState('');
  const [executing, setExecuting] = useState(false);
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const lastClearedResultId = localStorage.getItem(`clear_id_${id}`);
  
  // Tab-specific states
  const [viewMode, setViewMode] = useState('list'); // list or tree
  const [toasts, setToasts] = useState([]);
  
  const resultEndRef = useRef(null);

  const addToast = React.useCallback((title, type = 'info') => {
    const toastId = Math.random().toString(36).substring(2, 11);
    setToasts(prev => [...prev, { id: toastId, title, type }]);
    setTimeout(() => {
      setToasts(prev => prev.filter(t => t.id !== toastId));
    }, 4000);
  }, []);

  const fetchDetails = React.useCallback(async () => {
    try {
      // Fetch agent info first as it's critical for rendering
      const agentData = await agentsApi.get(id);
      setAgent(agentData.agent);
      
      // Fetch tactical data in parallel, but allow them to fail without crashing the whole view
      const [resultsRes, pendingRes] = await Promise.allSettled([
        tasksApi.results(id),
        tasksApi.pending(id)
      ]);

      if (resultsRes.status === 'fulfilled') {
        setResults(resultsRes.value.results || []);
      } else {
        console.error('Tactical results fetch failed:', resultsRes.reason);
      }

      if (pendingRes.status === 'fulfilled') {
        setPendingTasks(pendingRes.value.tasks || []);
      } else {
        console.error('Pending tasks fetch failed:', pendingRes.reason);
      }
      
    } catch (err) {
      console.error('Core agent fetch failed:', err);
      addToast('Critical Sync Error: Agent unreachable', 'error');
    } finally {
      setLoading(false);
    }
  }, [id, addToast]);

  const fetchDetailsRef = useRef(fetchDetails);
  
  useEffect(() => {
    fetchDetailsRef.current = fetchDetails;
  }, [fetchDetails]);

  useEffect(() => {
    const currentFetch = () => fetchDetailsRef.current();
    currentFetch();
    const interval = setInterval(currentFetch, 3000);
    return () => clearInterval(interval);
  }, [id]);

  useEffect(() => {
    if (resultEndRef.current) {
      resultEndRef.current.scrollIntoView({ behavior: 'smooth' });
    }
  }, [results, pendingTasks]);

  const handleCommand = async (e) => {
    e.preventDefault();
    if (!command.trim() || executing) return;
    setExecuting(true);
    try {
      await tasksApi.create(id, 'shell', { command });
      setCommand('');
      addToast('Command dispatched', 'success');
    } catch (err) {
      addToast(err.message, 'error');
    } finally {
      setExecuting(false);
    }
  };

  const handleQuickAction = async (type, payload) => {
    try {
      await tasksApi.create(id, type, payload);
      addToast(`${type.toUpperCase()} task queued`, 'success');
    } catch (err) {
      addToast(err.message, 'error');
    }
  };

  const getLatestResult = (type) => {
    return results.slice().reverse().find(r => r.task_type === type || r.task_type === `${type}_json`);
  };

  const renderOutput = (res) => {
    if (!res.task_result) return <span className="text-slate-600 italic">No output received</span>;
    
    if (res.task_type.includes('json')) {
        try {
            const data = JSON.parse(res.task_result);
            return <pre className="text-[11px] text-emerald-500/80 leading-relaxed overflow-x-auto">{JSON.stringify(data, null, 2)}</pre>;
        } catch { /* fallback to text */ }
    }
    
    return <pre className="text-[11px] text-slate-300 leading-relaxed whitespace-pre-wrap overflow-x-auto">{res.task_result}</pre>;
  };

  if (loading || !agent) {
    return (
      <div className="h-screen flex items-center justify-center flex-col bg-black">
        <Loader2 className="w-10 h-10 text-primary animate-spin mb-4" />
        <p className="text-[10px] font-black uppercase tracking-[0.5em] text-slate-600">Establishing Secure Tunnel</p>
      </div>
    );
  }

  const isOnline = agent.connection_status === 'online';

  return (
    <div className="h-screen flex flex-col bg-black overflow-hidden font-sans">
      {/* ── Top Bar: Mission Header ── */}
      <header className="h-16 border-b border-border bg-surface flex items-center justify-between px-6 shrink-0 relative z-20">
        <div className="flex items-center gap-6">
          <Link to="/agents" className="p-2 hover:bg-white/5 rounded-lg text-slate-500 hover:text-white transition-all">
            <ChevronLeft className="w-5 h-5" />
          </Link>
          <div className="h-8 w-px bg-border" />
          <div className="flex items-center gap-4">
            <div className={`w-3 h-3 rounded-full ${isOnline ? 'bg-primary shadow-[0_0_10px_rgba(0,242,255,0.6)]' : 'bg-slate-800'}`} />
            <div>
              <h1 className="text-sm font-black text-white uppercase tracking-widest leading-none mb-1">{agent.hostname}</h1>
              <p className="text-[9px] font-mono text-slate-600">{agent.id} • {agent.ip_address}</p>
            </div>
          </div>
        </div>

        <div className="flex items-center gap-4">
          <div className="flex items-center gap-6 bg-white/2 px-4 py-2 rounded-xl border border-white/5">
             <div className="flex flex-col items-end">
                <span className="text-[8px] font-black text-slate-600 uppercase tracking-widest">OS Environment</span>
                <span className="text-[10px] font-bold text-slate-300 uppercase tracking-tighter">{agent.os} {agent.arch}</span>
             </div>
             <div className="h-6 w-px bg-border" />
             <div className="flex flex-col items-end">
                <span className="text-[8px] font-black text-slate-600 uppercase tracking-widest">Beacon Frequency</span>
                <span className="text-[10px] font-bold text-slate-300 uppercase tracking-tighter">{agent.beacon_interval}s</span>
             </div>
          </div>
          <button onClick={() => setSidebarCollapsed(!sidebarCollapsed)} className="p-2.5 rounded-xl border border-border bg-surface hover:border-slate-700 text-slate-500 transition-all">
            <Menu className="w-5 h-5" />
          </button>
        </div>
      </header>

      <div className="flex-1 flex overflow-hidden">
        {/* ── Left Sidebar: Intel & Ops ── */}
        <aside className={`${sidebarCollapsed ? 'w-0 opacity-0' : 'w-80 opacity-100'} border-r border-border bg-black transition-all duration-300 overflow-y-auto overflow-x-hidden flex flex-col`}>
          <div className="p-6 space-y-8">
            {/* Action Group: Discovery */}
            <div className="space-y-4">
                <h4 className="text-[10px] font-black text-slate-600 uppercase tracking-[0.2em]">Live Discovery</h4>
                <div className="grid grid-cols-2 gap-2">
                    {[
                        { label: 'Capture', icon: Monitor, type: 'screenshot' },
                        { label: 'Network', icon: Globe, type: 'netstat_json' },
                        { label: 'Processes', icon: Cpu, type: 'ps_json' },
                        { label: 'Explorer', icon: Folder, type: 'ls_json' },
                    ].map(btn => (
                        <button 
                            key={btn.type}
                            onClick={() => handleQuickAction(btn.type, btn.type === 'ls_json' ? {path: '.'} : {})}
                            className="flex flex-col items-center justify-center p-4 rounded-xl border border-border bg-surface hover:border-primary/40 hover:bg-primary/5 transition-all group"
                        >
                            <btn.icon className="w-5 h-5 text-slate-600 group-hover:text-primary transition-colors mb-2" />
                            <span className="text-[9px] font-black text-slate-500 uppercase tracking-widest group-hover:text-slate-300">{btn.label}</span>
                        </button>
                    ))}
                </div>
            </div>

            {/* Action Group: Payload */}
            <div className="space-y-4">
                <h4 className="text-[10px] font-black text-slate-600 uppercase tracking-[0.2em]">Operational Intel</h4>
                <div className="space-y-2">
                    <div className="p-4 rounded-xl bg-surface border border-border group hover:border-emerald-500/30 transition-all">
                        <div className="flex items-center justify-between mb-3">
                            <span className="text-[9px] font-black text-emerald-500 uppercase tracking-widest">System Integrity</span>
                            <ShieldCheck className="w-3.5 h-3.5 text-emerald-500/50" />
                        </div>
                        <div className="flex items-center gap-4">
                            <div className="flex-1 h-1 bg-white/5 rounded-full overflow-hidden">
                                <div className="h-full bg-emerald-500 w-[90%] shadow-[0_0_8px_rgba(0,255,157,0.4)]" />
                            </div>
                            <span className="text-[10px] font-bold text-slate-400">90%</span>
                        </div>
                    </div>
                </div>
            </div>

            {/* Critical Actions */}
            <div className="space-y-4 pt-4 border-t border-border">
                <h4 className="text-[10px] font-black text-red-500/60 uppercase tracking-[0.2em]">Destructive Ops</h4>
                <div className="flex gap-2">
                    <button 
                        onClick={() => confirm('INITIATE SELF-DESTRUCT?') && handleQuickAction('self_destruct', {})}
                        className="flex-1 flex items-center justify-center gap-3 py-3 rounded-xl border border-red-500/20 bg-red-500/5 text-red-500 hover:bg-red-500/10 transition-all"
                    >
                        <Bomb className="w-4 h-4" />
                        <span className="text-[10px] font-black uppercase tracking-widest">Self Destruct</span>
                    </button>
                </div>
            </div>
          </div>
        </aside>

        {/* ── Main Workspace: Interaction ── */}
        <main className="flex-1 flex flex-col min-w-0 bg-black relative">
          {/* Tab Navigation */}
          <div className="h-12 border-b border-border bg-surface flex items-center px-8 gap-10 shrink-0">
            {[
              { id: 'console', label: 'Tactical Console', icon: TerminalIcon },
              { id: 'processes', label: 'Process Audit', icon: Cpu },
              { id: 'files', label: 'File Exfiltrator', icon: Folder },
              { id: 'network', label: 'Network Graph', icon: Globe },
            ].map(tab => (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-3 h-full border-b-2 transition-all group ${
                  activeTab === tab.id 
                    ? 'border-primary text-white' 
                    : 'border-transparent text-slate-600 hover:text-slate-400'
                }`}
              >
                <tab.icon className={`w-4 h-4 transition-colors ${activeTab === tab.id ? 'text-primary' : 'text-slate-700 group-hover:text-slate-500'}`} />
                <span className="text-[10px] font-black uppercase tracking-[0.2em]">{tab.label}</span>
              </button>
            ))}
          </div>

          {/* Tab Content */}
          <div className="flex-1 overflow-hidden relative flex flex-col">
            {activeTab === 'console' && (
              <div className="flex-1 flex flex-col overflow-hidden">
                  <div className="flex-1 overflow-y-auto p-8 space-y-6 scrollbar-thin bg-[#020202]">
                    {results.length === 0 && pendingTasks.length === 0 ? (
                        <div className="h-full flex flex-col items-center justify-center opacity-10">
                            <TerminalIcon className="w-24 h-24 mb-6" />
                            <p className="text-xl font-black uppercase tracking-[0.5em]">Awaiting Link</p>
                        </div>
                    ) : (
                        results.filter(r => !lastClearedResultId || r.id > lastClearedResultId).map((res) => (
                            <div key={res.id} className="animate-in fade-in slide-in-from-bottom-2 duration-500">
                                <div className="flex items-center gap-3 mb-3">
                                    <span className="text-[9px] font-black px-2 py-0.5 rounded bg-white/5 text-slate-500 uppercase tracking-widest">{res.task_type}</span>
                                    <span className="text-[9px] font-bold text-slate-700">{format(new Date(res.created_at), 'HH:mm:ss')}</span>
                                    <div className="h-px flex-1 bg-white/5" />
                                    {res.status === 'success' ? <CheckCircle2 className="w-3.5 h-3.5 text-emerald-500/50" /> : <AlertCircle className="w-3.5 h-3.5 text-red-500/50" />}
                                </div>
                                <div className="pl-4 border-l border-white/5 ml-1">
                                    <div className="flex items-center gap-2 text-white/40 mb-3 font-mono text-[11px]">
                                        <span className="text-primary font-black">$</span>
                                        <span className="font-bold">{(JSON.parse(res.task_payload || '{}').command) || res.task_type}</span>
                                    </div>
                                    <div className="bg-white/[0.02] border border-white/5 rounded-xl p-5 shadow-inner">
                                        {renderOutput(res)}
                                    </div>
                                </div>
                            </div>
                        ))
                    )}
                    {pendingTasks.map(task => (
                        <div key={task.id} className="opacity-40 animate-pulse">
                            <div className="flex items-center gap-3 mb-3">
                                <span className="text-[9px] font-black px-2 py-0.5 rounded bg-primary/10 text-primary uppercase tracking-widest">{task.task_type}</span>
                                <Loader2 className="w-3 h-3 animate-spin text-primary" />
                            </div>
                            <div className="pl-4 border-l border-primary/20 ml-1">
                                <div className="text-slate-500 font-mono text-[11px]">$ {(JSON.parse(task.task_payload || '{}').command) || task.task_type}</div>
                            </div>
                        </div>
                    ))}
                    <div ref={resultEndRef} />
                  </div>
                  
                  {/* Console Input */}
                  <div className="p-8 bg-surface border-t border-border relative z-10 shadow-[0_-20px_40px_rgba(0,0,0,0.5)]">
                    <form onSubmit={handleCommand} className="relative group max-w-5xl mx-auto">
                        <div className="absolute left-6 top-1/2 -translate-y-1/2 text-primary font-black text-xl">$</div>
                        <input 
                            type="text" 
                            value={command}
                            onChange={e => setCommand(e.target.value)}
                            placeholder="EXECUTE TACTICAL COMMAND..."
                            className="w-full bg-black border-2 border-border rounded-2xl pl-14 pr-32 py-5 text-white font-mono text-base outline-none focus:border-primary/40 transition-all uppercase tracking-widest placeholder:text-slate-800"
                        />
                        <button 
                            type="submit"
                            disabled={!command.trim() || executing}
                            className="absolute right-3 top-1/2 -translate-y-1/2 h-12 px-8 rounded-xl bg-primary text-black font-black uppercase tracking-widest text-[10px] hover:scale-105 active:scale-95 transition-all flex items-center gap-3 disabled:opacity-20"
                        >
                            {executing ? <Loader2 className="w-4 h-4 animate-spin" /> : <Send className="w-4 h-4" />}
                            Execute
                        </button>
                    </form>
                  </div>
              </div>
            )}

            {activeTab === 'processes' && (
              <div className="flex-1 flex flex-col overflow-hidden p-8">
                  <div className="dash-card flex-1 flex flex-col overflow-hidden !p-0">
                      <div className="p-6 border-b border-border flex items-center justify-between bg-white/[0.02]">
                          <div className="flex items-center gap-4">
                              <div className="p-2 rounded-lg bg-primary/10 text-primary">
                                  <Cpu className="w-5 h-5" />
                              </div>
                              <div>
                                  <h3 className="text-xs font-black uppercase tracking-widest text-white">Process Monitor</h3>
                                  <p className="text-[9px] font-bold text-slate-600 uppercase tracking-widest">Real-time task synchronization</p>
                              </div>
                          </div>
                          <div className="flex items-center gap-4">
                              <div className="flex bg-black p-1 rounded-lg border border-border">
                                  <button onClick={() => setViewMode('list')} className={`px-4 py-1.5 rounded-md text-[9px] font-black uppercase tracking-widest transition-all ${viewMode === 'list' ? 'bg-primary text-black' : 'text-slate-600 hover:text-slate-400'}`}>List</button>
                                  <button onClick={() => setViewMode('tree')} className={`px-4 py-1.5 rounded-md text-[9px] font-black uppercase tracking-widest transition-all ${viewMode === 'tree' ? 'bg-primary text-black' : 'text-slate-600 hover:text-slate-400'}`}>Tree</button>
                              </div>
                              <button onClick={() => handleQuickAction('ps_json', {})} className="p-2.5 rounded-xl border border-border hover:border-primary/40 transition-all text-slate-500 hover:text-primary">
                                  <RefreshCw className="w-4 h-4" />
                              </button>
                          </div>
                      </div>
                      
                      <div className="flex-1 overflow-y-auto scrollbar-thin p-6">
                        {viewMode === 'list' ? (
                            <table className="w-full text-left">
                                <thead>
                                    <tr className="border-b border-border">
                                        <th className="pb-4 text-[9px] font-black text-slate-600 uppercase tracking-widest">PID</th>
                                        <th className="pb-4 text-[9px] font-black text-slate-600 uppercase tracking-widest">Process Name</th>
                                        <th className="pb-4 text-[9px] font-black text-slate-600 uppercase tracking-widest">PPID</th>
                                        <th className="pb-4 text-[9px] font-black text-slate-600 uppercase tracking-widest text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody className="divide-y divide-border">
                                    {(() => {
                                        try {
                                            const res = getLatestResult('ps');
                                            if (!res?.task_result) return null;
                                            const processes = JSON.parse(res.task_result);
                                            return processes.map(p => (
                                                <tr key={p.pid} className="group hover:bg-white/[0.02] transition-colors">
                                                    <td className="py-3 text-xs font-mono text-slate-500">{p.pid}</td>
                                                    <td className="py-3">
                                                        <div className="flex items-center gap-3">
                                                            <span className={`text-xs font-bold ${Number(p.pid) === Number(agent.pid) ? 'text-primary' : 'text-slate-300'}`}>{p.name}</span>
                                                            {Number(p.pid) === Number(agent.pid) && <span className="text-[8px] font-black bg-primary/10 text-primary border border-primary/20 px-1 rounded uppercase tracking-tighter">Self</span>}
                                                        </div>
                                                    </td>
                                                    <td className="py-3 text-xs font-mono text-slate-600">{p.ppid}</td>
                                                    <td className="py-3 text-right">
                                                        <button className="opacity-0 group-hover:opacity-100 p-1.5 rounded hover:bg-red-500/10 text-slate-700 hover:text-red-500 transition-all">
                                                            <Trash2 className="w-3.5 h-3.5" />
                                                        </button>
                                                    </td>
                                                </tr>
                                            ));
                                        } catch {
                                            return (
                                                <tr>
                                                    <td colSpan="4" className="py-10 text-center text-[10px] text-slate-600 uppercase italic">
                                                        Failed to parse process telemetry
                                                    </td>
                                                </tr>
                                            );
                                        }
                                    })()}
                                </tbody>
                            </table>
                        ) : (
                            <div className="space-y-1">
                                {/* Tree view logic would go here, simplified for now */}
                                <p className="text-center py-20 text-[10px] font-black text-slate-800 uppercase tracking-[0.3em]">Building Tactical Tree Structure...</p>
                            </div>
                        )}
                      </div>
                  </div>
              </div>
            )}

            {/* Other tabs would follow similar structure... */}
            {activeTab === 'files' && (
                <div className="flex-1 flex items-center justify-center text-slate-800 uppercase font-black tracking-[0.4em]">Exfiltration Module Active</div>
            )}
            {activeTab === 'network' && (
                <div className="flex-1 flex items-center justify-center text-slate-800 uppercase font-black tracking-[0.4em]">Network Mapping Ready</div>
            )}
          </div>
        </main>
      </div>

      {/* ── Toast Hub ── */}
      <div className="fixed bottom-10 right-10 flex flex-col gap-3 z-50 pointer-events-none">
        {toasts.map(toast => (
          <div 
            key={toast.id}
            className={`pointer-events-auto flex items-center gap-4 px-6 py-4 rounded-2xl border shadow-2xl animate-in slide-in-from-right duration-500 ${
              toast.type === 'success' ? 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400' :
              toast.type === 'error' ? 'bg-red-500/10 border-red-500/20 text-red-400' :
              'bg-surface border-border text-slate-300'
            }`}
          >
            {toast.type === 'success' ? <CheckCircle2 className="w-5 h-5" /> : <AlertCircle className="w-5 h-5" />}
            <span className="text-[10px] font-black uppercase tracking-widest">{toast.title}</span>
          </div>
        ))}
      </div>
    </div>
  );
};

export default AgentDetailPage;
